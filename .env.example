# Директория для логирования
WEBHOOK_LOG=./logs/webhook.log

# Директория для логирования
VENDOR_LOG=./logs/vendor.log

# Директория для хранения данных
DATA_DIR=../data

# Базовый URL решения. Рекомендуется выделять решению отдельный (под)домен.
APP_BASE_URL=https://example.com

# Следующие параметры идентификации решения нужно поулчить в личном кабинете разработчика:

# Идентификатор решения (appId)
APP_ID=

# Глобальный идентификатор (appUid)
APP_UID=

# Секретный ключ
SECRET_KEY=

# Драйвер PDO, например: pdo_pgsql
DB_DRIVER=pdo_pgsql

# Имя хоста СУБД
DB_HOST=

# Имя базы данных СУБД
DB_NAME=

# Порт хоста СУБД
DB_PORT=5432

# Имя пользователя СУБД
DB_USER=

# Пароль пользователя СУБД
DB_PASSWORD=
